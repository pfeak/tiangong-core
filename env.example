# Tiangong Core - environment example
# Copy to `.env` (either repo root or your --workspace directory) and fill values.

# Model selection
TIANGONG_MODEL=openai/gpt-4.1-mini

# Provider auth
TIANGONG_API_KEY=

# Provider base URL (e.g. OpenAI-compatible gateway)
# TIANGONG_BASE_URL=

# Optional: DashScope (Aliyun Model Studio) OpenAI-compatible endpoint
# When TIANGONG_BASE_URL points to DashScope (e.g. https://dashscope.aliyuncs.com/compatible-mode/v1)
# and model is a Qwen/Qwen3.* model, LiteLLMProvider will treat it as "dashscope" provider.
#
# Enable DashScope web search (see Aliyun docs:
# https://help.aliyun.com/zh/model-studio/web-search#312c12c262fsr)
# 1 / true / yes / on = enabled
# TIANGONG_DASHSCOPE_ENABLE_SEARCH=true
#
# Optional fine-grained DashScope search_options, JSON string passed through as-is.
# Example below enables stronger search with sources:
# TIANGONG_DASHSCOPE_SEARCH_OPTIONS='{"search_strategy":"max","forced_search":true,"enable_source":true}'
#
# Enable DashScope mixed text+image output (enable_text_image_mixed)
# TIANGONG_DASHSCOPE_ENABLE_TEXT_IMAGE_MIXED=false

# Behavior
# 1 = restrict tools to workspace (default), 0 = allow broader access
TIANGONG_RESTRICT_WORKSPACE=1

# Tool/runtime limits
TIANGONG_SHELL_TIMEOUT_S=30
TIANGONG_MAX_TOOL_ITER=12

# Session key scheme
# channel_chat (default) = "<channel>:<chat_id>"
# agent_chat             = "<agent_id>:<chat_id>"
# TIANGONG_SESSION_KEY_SCHEME=channel_chat

# CLI sender identity (for allowlist / audit)
# Defaults to $USER or "local-cli" when unset.
# TIANGONG_CLI_SENDER=
