# Tiangong Core - environment example
# Copy to `.env` (either repo root or your --workspace directory) and fill values.

# Model selection
TIANGONG_MODEL=openai/gpt-4.1-mini

# Provider auth
TIANGONG_API_KEY=

# Provider base URL
# TIANGONG_BASE_URL=

# Behavior
# 1 = restrict tools to workspace (default), 0 = allow broader access
TIANGONG_RESTRICT_WORKSPACE=1

# Tool/runtime limits
TIANGONG_SHELL_TIMEOUT_S=30
TIANGONG_MAX_TOOL_ITER=12

# Session key scheme
# channel_chat (default) = "<channel>:<chat_id>"
# agent_chat             = "<agent_id>:<chat_id>"
# TIANGONG_SESSION_KEY_SCHEME=channel_chat

# CLI sender identity (for allowlist / audit)
# Defaults to $USER or "local-cli" when unset.
# TIANGONG_CLI_SENDER=
